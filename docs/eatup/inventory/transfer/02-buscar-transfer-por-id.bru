meta {
  name: 02-buscar-transfer-por-id
  type: http
  seq: 2
}

get {
  url: http://localhost:8080/inventory/api/v1/transfers/:transferId
  auth: inherit
}

tests {
  test("Transfer encontrado", () => {
    expect(res.status).to.equal(200);
  });
  
  test("Tiene datos correctos", () => {
    expect(res.body.id).to.exist;
    expect(res.body.sedeOrigen).to.exist;
    expect(res.body.sedeDestino).to.exist;
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
