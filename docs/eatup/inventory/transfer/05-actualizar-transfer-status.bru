meta {
  name: 05-actualizar-transfer-status
  type: http
  seq: 5
}

patch {
  url: http://localhost:8080/inventory/api/v1/transfers/:transferId/status
  body: json
  auth: inherit
}

body:json {
  {
    "estado": "COMPLETED"
  }
}

tests {
  test("Status actualizado", () => {
    expect(res.status).to.equal(200);
  });
  
  test("Estado es COMPLETED", () => {
    expect(res.body.estado).to.equal("COMPLETED");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
