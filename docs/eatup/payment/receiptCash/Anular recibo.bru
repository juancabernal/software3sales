script:post-response {
  const data = res.getBody();
  
  test("Debe retornar 200 OK", function() {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("El status del recibo debe ser CANCELLED", function() {
      expect(data.status).to.equal("CANCELLED");
  });
  
  test("cancelledAt no debe ser null", function() {
      expect(data.cancelledAt).to.not.be.null;
  });
  
  test("El id del recibo debe mantenerse", function() {
      expect(data.id).to.be.a("string");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
