meta {
  name: set active
  type: http
  seq: 2
}

patch {
  url: http://localhost:8080/comercialapi/v1/sellers/{{sellerId}}/status
  body: json
  auth: inherit
}

body:json {
  {
    "status": "ACTIVE"
  }
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("Status is ACTIVE", function() {
    expect(res.getBody().status).to.equal("ACTIVE");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
