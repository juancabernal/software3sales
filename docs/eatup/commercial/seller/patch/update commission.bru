meta {
  name: update commission
  type: http
  seq: 3
}

patch {
  url: http://localhost:8080/comercialapi/v1/sellers/{{sellerId}}
  body: json
  auth: inherit
}

body:json {
  {
    "commissionPercentage": 12.5
  }
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("Commission was updated", function() {
    expect(res.getBody().commissionPercentage).to.equal(12.5);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
