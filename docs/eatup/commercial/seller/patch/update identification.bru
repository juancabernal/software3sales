meta {
  name: update identification
  type: http
  seq: 4
}

patch {
  url: http://localhost:8080/comercialapi/v1/sellers/{{sellerId}}
  body: json
  auth: inherit
}

body:json {
  {
    "identificationNumber": "1111132"
  }
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("Identification was updated", function() {
    expect(res.getBody().identificationNumber).to.equal("1111132");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
